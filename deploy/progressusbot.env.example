# Скопируй в корень репозитория как .env и заполни.

# --- API бота (FastAPI progressusbot_api) ---
# Обязательно в проде:
PROGRESSUSBOT_API_KEY=сгенерируй-длинную-случайную-строку

# local = графы внутри процесса uvicorn/docker (по умолчанию)
# langgraph = вызов через LANGGRAPH_API_URL (threads/runs)
PROGRESSUSBOT_BACKEND=local

# Если за прокси с префиксом (редко):
# PROGRESSUSBOT_ROOT_PATH=/api

# CORS для браузера (через запятую):
# PROGRESSUSBOT_CORS_ORIGINS=https://progressusbot.ru

# Имена графов из langgraph.json (для режима langgraph):
# generate_agent — только генерация (без git push в конце).
# unified — generate → validate с деплоем (в state может быть deploy_url).
# PROGRESSUSBOT_GRAPH_GENERATE=generate_agent
# PROGRESSUSBOT_GRAPH_GENERATE=unified
# PROGRESSUSBOT_GRAPH_EDIT=validate_edit

# --- Режим langgraph (если PROGRESSUSBOT_BACKEND=langgraph) ---
# LANGGRAPH_API_URL=http://127.0.0.1:2024
# LANGGRAPH_API_KEY=
# LANGSMITH_API_KEY=

# --- LLM / агенты (как в проекте) ---
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
