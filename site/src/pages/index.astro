---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { withBase } from '../utils/withBase';
---

<BaseLayout title="Личный дневник трат: Главная">
  <main class="w-full min-h-screen bg-white">
    <!-- Hero Section -->
    <Hero />

    <!-- Features Section -->
    <section class="py-20 px-4 md:px-8 lg:px-16" id="features">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-12 text-center">Почему это удобно?</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="p-8 bg-slate-50 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-semibold mb-4 text-slate-900">Простота ввода</h3>
            <p class="text-slate-600 leading-relaxed">Записывайте траты за секунды, не отвлекаясь от дел. Никаких сложных полей и таблиц.</p>
          </div>
          <div class="p-8 bg-slate-50 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-semibold mb-4 text-slate-900">Понятная аналитика</h3>
            <p class="text-slate-600 leading-relaxed">Смотрите, на что уходят деньги в конце недели или месяца с помощью наглядных графиков.</p>
          </div>
          <div class="p-8 bg-slate-50 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-semibold mb-4 text-slate-900">Приватность</h3>
            <p class="text-slate-600 leading-relaxed">Ваши финансовые данные хранятся только на вашем устройстве. Мы заботимся о безопасности.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Beta Signup Section -->
    <section class="py-20 px-4 bg-slate-900 text-white" id="beta">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Присоединяйтесь к бета-тесту</h2>
        <p class="text-lg text-slate-300 mb-10">Будьте одними из первых, кто попробует новый способ ведения дневника трат. Просто оставьте email — и мы пришлем приглашение, как только будем готовы.</p>
        
        <form action="#" method="POST" class="flex flex-col sm:flex-row gap-4 justify-center">
          <input 
            type="email" 
            placeholder="Ваш email" 
            required
            class="px-6 py-4 rounded-xl text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 w-full sm:w-80"
          />
          <button 
            type="submit" 
            class="px-8 py-4 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-colors"
          >
            Подписаться
          </button>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
